# ============================================================================
# CONFIGURACIÓN DE ENTORNO - EJEMPLO
# ============================================================================
# Copia este archivo a .env y completa con tus valores
# ¡NUNCA comitees .env con secretos reales a git!

# ============================================================================
# DJANGO
# ============================================================================
DEBUG=True
SECRET_KEY=tu-clave-secreta-super-larga-aqui-cambiar-en-produccion
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# BASE DE DATOS
# ============================================================================
# Formato: postgresql://usuario:contraseña@host:puerto/base_datos
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/pokealert

# ============================================================================
# REDIS (Cache y Celery)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# CORREO (para notificaciones de alertas)
# ============================================================================
# En desarrollo (consola):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# En producción (SendGrid vía API HTTPS / anymail):
# EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend
# SENDGRID_API_KEY=tu-api-key-de-sendgrid
# EMAIL_FROM=tu-email-verificado@gmail.com

# ============================================================================
# API POKÉMON TCG
# ============================================================================
POKEMONTCG_API_URL=https://api.pokemontcg.io/v2
POKEMONTCG_API_KEY=  # Si es necesario

# ============================================================================
# SEGURIDAD DE TAREAS / CRON
# ============================================================================
CRON_SECRET_TOKEN=tu-token-secreto-para-disparar-tareas-externas

# ============================================================================
# HERRAMIENTAS EXTERNAS
# ============================================================================
# Sentry para error tracking (opcional)
SENTRY_DSN=

# ============================================================================
# DESARROLLO
# ============================================================================
USE_DJANGO_DEBUG_TOOLBAR=False
ENVIRONMENT=development